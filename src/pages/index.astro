---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="asdforge" bodyClass="home-body">
  <main>
    <div class="container">

      <header>
        <h1 class="wordmark">
          <span id="key-a" class="key">a</span><span id="key-s" class="key">s</span><span id="key-d" class="key">d</span><span
            id="key-f-el" class="key key-f">f<span class="underscore">_</span></span><span class="forge-rest">orge</span>
        </h1>
        <p class="tagline">we're making things</p>
      </header>

      <section class="section">
        <span class="section-label">// who</span>
        <div class="founders">
          <span class="founder">Jared Arnold</span>
          <span class="sep">·</span>
          <span class="founder">Ian Switzer</span>
          <span class="sep">·</span>
          <a href="https://devines.org" class="founder founder-link" target="_blank" rel="noopener">Joshua Devine</a>
        </div>
      </section>

      <section class="section">
        <span class="section-label">// what</span>
        <div class="projects-placeholder">
          <span class="prompt">$</span>
          <span class="prompt-text"> asdforge --list-projects</span>
          <br />
          <span class="prompt-output">building something worth using<span class="cursor">_</span></span>
        </div>
      </section>

      <footer>
        <a href="https://github.com/asdforge" class="footer-link" target="_blank" rel="noopener">
          github ↗
        </a>
      </footer>

    </div>
  </main>
</BaseLayout>

<style>
  :global(.home-body) {
    background: var(--bg);
    margin: 0;
    padding: 0;
  }

  main {
    min-height: 100vh;
    background: var(--bg);
    font-family: 'Courier New', Courier, monospace;
    color: var(--text);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .container {
    max-width: 640px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  /* ── wordmark ── */

  .wordmark {
    margin: 0;
    font-size: clamp(2rem, 8vw, 3.6rem);
    font-weight: bold;
    letter-spacing: -0.02em;
    display: flex;
    align-items: center;
    gap: 2px;
    line-height: 1;
    padding: 0.2em 0 0.6em;
    overflow: visible;
  }

  .key {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1em;
    height: 1em;
    background: var(--bg-key);
    border: 1.5px solid var(--key-border);
    border-radius: 6px;
    font-size: 0.78em;
    color: var(--accent-mid);
    box-shadow:
      0 4px 0 var(--key-shadow),
      0 6px 10px rgba(0, 0, 0, 0.6),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    position: relative;
    flex-shrink: 0;
    cursor: pointer;
    user-select: none;
    transition:
      transform 0.1s ease,
      box-shadow 0.1s ease;
  }

  .key:hover {
    transform: scale(1.15);
    box-shadow:
      0 5px 0 var(--key-shadow),
      0 8px 16px rgba(0, 0, 0, 0.7),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .key:active,
  .key.pressed {
    transform: translateY(3px) scale(1.05);
    box-shadow:
      0 1px 0 var(--key-shadow),
      0 2px 4px rgba(0, 0, 0, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.02);
    transition-duration: 0.05s;
  }

  .key-f {
    color: var(--accent);
    border-color: var(--accent-border);
    background: var(--accent-dim);
    box-shadow:
      0 4px 0 rgba(76, 201, 240, 0.2),
      0 6px 14px rgba(0, 0, 0, 0.6),
      0 0 16px rgba(76, 201, 240, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .key-f:hover {
    box-shadow:
      0 5px 0 rgba(76, 201, 240, 0.25),
      0 8px 16px rgba(0, 0, 0, 0.7),
      0 0 22px rgba(76, 201, 240, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .key-f:active,
  .key-f.pressed {
    box-shadow:
      0 1px 0 rgba(76, 201, 240, 0.15),
      0 2px 4px rgba(0, 0, 0, 0.4),
      0 0 10px rgba(76, 201, 240, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.02);
  }

  .underscore {
    font-size: 0.5em;
    position: absolute;
    bottom: 0.05em;
    left: 50%;
    transform: translateX(-50%);
    color: var(--accent);
    opacity: 0.75;
    line-height: 1;
  }

  .forge-rest {
    color: var(--accent);
    margin-left: -2px;
    font-size: 0.78em;
  }

  /* ── tagline ── */

  .tagline {
    margin: 1rem 0 0;
    font-size: clamp(0.8rem, 2.5vw, 0.95rem);
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }

  /* ── sections ── */

  .section {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .section-label {
    font-size: 0.75rem;
    color: var(--accent-mid);
    letter-spacing: 0.1em;
    text-transform: lowercase;
  }

  /* ── founders ── */

  .founders {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: clamp(0.95rem, 3vw, 1.1rem);
  }

  .founder {
    color: var(--text);
  }

  .founder-link {
    text-decoration: none;
    color: var(--text);
    transition: color 0.2s;
  }

  .founder-link:hover {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--accent-border);
  }

  .sep {
    color: var(--text-faint);
    user-select: none;
  }

  /* ── projects ── */

  .projects-placeholder {
    font-size: clamp(0.85rem, 2.5vw, 1rem);
    line-height: 1.8;
    color: var(--text-muted);
    padding: 1rem 1.25rem;
    background: var(--bg-surface);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 6px;
    border-left: 2px solid var(--accent-border);
  }

  .prompt {
    color: var(--accent);
    user-select: none;
  }

  .prompt-text {
    color: var(--text-muted);
  }

  .prompt-output {
    color: var(--text-faint);
    display: block;
    padding-left: 1.1rem;
  }

  .cursor {
    color: var(--accent);
    animation: blink 1.1s step-end infinite;
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  /* ── footer ── */

  footer {
    padding-top: 0.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .footer-link {
    color: var(--text-faint);
    text-decoration: none;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    transition: color 0.2s;
  }

  .footer-link:hover {
    color: var(--text-muted);
  }
</style>

<script>
  const keyMap: Record<string, string> = { a: 'key-a', s: 'key-s', d: 'key-d', f: 'key-f-el' };

  document.addEventListener('keydown', (e) => {
    if (e.repeat || e.metaKey || e.ctrlKey || e.altKey) return;
    const id = keyMap[e.key.toLowerCase()];
    if (id) document.getElementById(id)?.classList.add('pressed');
  });

  document.addEventListener('keyup', (e) => {
    const id = keyMap[e.key.toLowerCase()];
    if (id) document.getElementById(id)?.classList.remove('pressed');
  });
</script>
